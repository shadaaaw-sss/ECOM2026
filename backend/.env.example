PORT=4000

# Database Configuration
# Option 1: Local PostgreSQL (recommended for development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/makhmal_db

# Option 2: Railway PostgreSQL (for production deployment)
# DATABASE_URL=postgresql://postgres:password@monorail.proxy.rlwy.net:14677/railway?sslmode=require

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# R2/Supabase Storage Configuration
R2_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/your-bucket-name

# File Upload Limits
MAX_IMAGE_SIZE_MB=5
MAX_IMAGES_PER_PRODUCT=8

# SMTP Configuration (for email verification and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Your Store" <your-email@gmail.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000